# Jarvis Voice Assistant - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://jarvis_user:your_secure_password@postgres:5432/jarvis

# PostgreSQL password (used by Docker Compose)
DB_PASSWORD=your_secure_password

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

# Secret key for Flask session encryption (use a random string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here

# Password to login to Jarvis web interface
APP_PASSWORD=jarvis2025

# Flask environment (production or development)
FLASK_ENV=production

# ============================================================================
# VOICE API KEYS
# ============================================================================

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/account/keys
# Cost: ~$5-20/month for daily use
ANTHROPIC_API_KEY=sk-ant-v0-xxxxxxxxxxxxxxxxxxxxx

# ElevenLabs API Key (for voice synthesis)
# Get from: https://elevenlabs.io/account/profile
# Cost: ~$2-10/month for regular use
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (for Whisper speech-to-text)
# Get from: https://platform.openai.com/account/api-keys
# Cost: ~$1-5/month for daily transcription
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# JARVIS VOICE CONFIGURATION
# ============================================================================

# Wake word to activate Jarvis (e.g., "jarvis", "hey jarvis")
JARVIS_WAKE_WORD=jarvis

# ElevenLabs voice ID (British voices recommended for Jarvis personality)
# Options: alistair (recommended), callum, ollie, grace, sophia, chris, alice
# Test at: https://elevenlabs.io/voice-lab
JARVIS_VOICE_ID=alistair

# Morning briefing schedule (cron format)
# Default: "0 6 * * *" = 6 AM every day
# Change to your preferred wake-up time
MORNING_BRIEFING_TIME="0 6 * * *"

# Timezone for scheduling and time-based features
# Options: America/Denver, America/New_York, Europe/London, etc.
TIMEZONE=America/Denver

# ============================================================================
# HOME ASSISTANT INTEGRATION (OPTIONAL)
# ============================================================================

# Home Assistant API URL (only if you have HA installed)
# Format: http://home-assistant.local:8123
# Leave empty to skip HA integration
HA_URL=

# Home Assistant API Token
# Generate in HA: Settings > Devices & Services > Tokens > Create Token
# Leave empty to skip HA integration
HA_TOKEN=

# ============================================================================
# CALENDAR INTEGRATION (OPTIONAL - for existing features)
# ============================================================================

# Google Calendar iCalendar URL for personal calendar
# Format: https://calendar.google.com/calendar/ical/...
PERSONAL_ICAL_URL=

# Canvas LMS iCalendar URL for assignments
# Get from Canvas: Settings > Calendar > Integrations > Subscribe
CANVAS_ICAL_URL=

# Sports calendar iCalendar URL
# Leave empty if not needed
SPORTS_ICAL_URL=

# ============================================================================
# PORCUPINE WAKE WORD DETECTION (OPTIONAL)
# ============================================================================

# Porcupine API Key for local wake word detection
# Get from: https://console.picovoice.ai
# Leave empty to use fallback detection (less accurate but works offline)
PORCUPINE_ACCESS_KEY=

# ============================================================================
# DOCKER-SPECIFIC (for Docker Compose)
# ============================================================================

# Docker network port mapping (usually 5000)
FLASK_PORT=5000

# PostgreSQL port (usually 5432)
DB_PORT=5432

# ============================================================================
# ADVANCED CONFIGURATION (OPTIONAL)
# ============================================================================

# Conversation context window size (number of exchanges to remember)
# Default: 10, increase for longer conversations but more API cost
CONVERSATION_CONTEXT_SIZE=10

# Memory decay threshold (days before old memories fade)
# Default: 30, increase to keep memories longer
MEMORY_DECAY_DAYS=30

# Briefing cache duration (seconds - don't regenerate within this time)
# Default: 3600 (1 hour), increase to save API calls
BRIEFING_CACHE_DURATION=3600

# ============================================================================
# Notes for Railway Deployment
# ============================================================================

# 1. Copy all REQUIRED variables to your Railway environment
# 2. Replace XXX placeholders with actual API keys
# 3. Generate a strong SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# 4. Use a unique DB_PASSWORD (at least 16 characters, mix of upper/lower/numbers)
# 5. Never expose .env file or API keys in git
# 6. Rotate API keys periodically (quarterly recommended)

# ============================================================================
# Getting Started Checklist
# ============================================================================

# [ ] Get Anthropic API key and add to ANTHROPIC_API_KEY
# [ ] Get ElevenLabs API key and add to ELEVENLABS_API_KEY
# [ ] Get OpenAI API key and add to OPENAI_API_KEY
# [ ] Generate SECRET_KEY with Python secrets module
# [ ] Create strong DB_PASSWORD
# [ ] Set APP_PASSWORD to login
# [ ] Copy this file to .env (chmod 600 .env for security)
# [ ] Test with: curl http://localhost:5000/api/config
# [ ] Configure Kindle Fire to access Jarvis web interface
# [ ] Adjust MORNING_BRIEFING_TIME to your wake time
# [ ] Test voice interaction: "Good morning"

# ============================================================================
